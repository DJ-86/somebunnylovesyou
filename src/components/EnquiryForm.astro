---
export interface Props {
  subject?: string;
  rabbitName?: string;
}

const { subject = 'General enquiry from website', rabbitName = '' } = Astro.props;

// Get Web3Forms key from environment variable (set in Netlify)
const web3FormsKey = import.meta.env.WEB3FORMS_KEY || 'YOUR_ACCESS_KEY';
---

<form
  id="enquiry-form"
  action="https://api.web3forms.com/submit"
  method="POST"
  class="space-y-5"
>
  <!-- Web3Forms access key from environment variable -->
  <input type="hidden" name="access_key" value="b44aa622-28a5-4b1f-9c4f-64956ee0aaee"/>
  <input type="hidden" name="subject" value={subject} />
  <input type="hidden" name="redirect" value="false" />
  <input type="checkbox" name="botcheck" class="hidden" style="display:none" />

  {rabbitName && (
    <input type="hidden" name="rabbit_interested_in" value={rabbitName} />
  )}

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
    <div>
      <label for="name" class="form-label">Your name *</label>
      <input type="text" id="name" name="name" required class="form-input" placeholder="Jane Smith" />
    </div>
    <div>
      <label for="phone" class="form-label">Phone number</label>
      <input type="tel" id="phone" name="phone" class="form-input" placeholder="07700 900000" />
    </div>
  </div>

  <div>
    <label for="email" class="form-label">Email address *</label>
    <input type="email" id="email" name="email" required class="form-input" placeholder="jane@example.com" />
  </div>

  <div>
    <label for="message" class="form-label">Your message *</label>
    <textarea
      id="message"
      name="message"
      required
      rows="4"
      class="form-input resize-none"
      placeholder={rabbitName ? `I'm interested in ${rabbitName}. I'd like to know more about...` : "Tell us what you're looking for..."}
    ></textarea>
  </div>

  <div id="form-result" class="hidden"></div>

  <button type="submit" class="btn-primary w-full text-center">
    Send Enquiry →
  </button>

  <p class="text-xs text-bunny-light text-center">
    We'll get back to you within 24 hours. No spam, ever.
  </p>
</form>

<script>
  const form = document.getElementById('enquiry-form') as HTMLFormElement;
  const result = document.getElementById('form-result');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Sending…';

    const data = new FormData(form);
    const response = await fetch('https://api.web3forms.com/submit', {
      method: 'POST',
      body: data,
    });

    const json = await response.json();

    if (json.success) {
      form.reset();
      btn.textContent = '✅ Sent!';
      if (result) {
        result.className = 'bg-green-50 border border-green-200 text-green-800 rounded-xl px-4 py-3 text-sm';
        result.textContent = "Thanks! We'll be in touch within 24 hours.";
      }
    } else {
      btn.disabled = false;
      btn.textContent = 'Send Enquiry →';
      if (result) {
        result.className = 'bg-red-50 border border-red-200 text-red-700 rounded-xl px-4 py-3 text-sm';
        result.textContent = 'Something went wrong. Please try again or email us directly.';
      }
    }
    result?.classList.remove('hidden');
  });
</script>
