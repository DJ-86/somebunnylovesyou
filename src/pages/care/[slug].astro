---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('care');
  return articles.map(article => ({
    params: { slug: article.slug },
    props: { article: article.data, body: article.body },
  }));
}

const { article, body } = Astro.props;

const categoryColors: Record<string, string> = {
  Feeding: 'bg-orange-100 text-orange-700',
  Housing: 'bg-blue-100 text-blue-700',
  Bonding: 'bg-pink-100 text-pink-700',
  'First-time owners': 'bg-green-100 text-green-700',
  Health: 'bg-red-100 text-red-700',
  Grooming: 'bg-purple-100 text-purple-700',
};
---

<Base title={article.title} description={article.title}>

  <article class="max-w-3xl mx-auto px-6 py-12">

    <!-- Back -->
    <a href="/care" class="inline-flex items-center gap-1 text-sm text-bunny-light hover:text-bunny-dark no-underline mb-8 transition-colors">
      ← All care guides
    </a>

    <!-- Header -->
    <div class="mb-8">
      <div class="flex items-center gap-3 mb-4">
        <span class={`text-xs font-medium px-3 py-1 rounded-full ${(article?.category && categoryColors[article.category]) || 'bg-gray-100 text-gray-700'}`}>
          {article.category}
        </span>
        <span class="text-xs text-bunny-light">{article.readTime}</span>
      </div>
      <div class="text-6xl mb-4">{article.emoji}</div>
      <h1 class="font-lora text-3xl md:text-4xl font-semibold text-bunny-dark leading-tight">
        {article.title}
      </h1>
    </div>

    <!-- Content -->
    <div class="prose prose-bunny max-w-none" set:html={body.replace(/^## (.+)$/gm, '<h2>$1</h2>').replace(/^### (.+)$/gm, '<h3>$1</h3>').replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>').replace(/\*(.+?)\*/g, '<em>$1</em>').replace(/^- (.+)$/gm, '<li>$1</li>').replace(/(<li>[\s\S]*?<\/li>)/gm, (m) => `<ul class="my-3 space-y-1">${m}</ul>`)}></div>

    <!-- CTA at end of article -->
      <div class="mt-12 pt-8 border-t border-tan bg-cream rounded-2xl p-6">
        <h3 class="font-lora font-semibold text-bunny-dark text-lg mb-2">
          Questions? We're happy to help.
        </h3>
        <p class="text-bunny-light text-sm mb-4">
        Even if you didn't buy your rabbit from us, feel free to get in touch. We love talking rabbits.
        </p>
      <div class="flex flex-wrap gap-3">
        <a href="/enquire" class="btn-primary text-sm">Ask us a question →</a>
        <a href="/care" class="btn-outline text-sm">More care guides</a>
      </div>
    </div>

  </article>

</Base>

<style>
  .prose h2 {
    font-family: 'Lora', serif;
    font-size: 1.25rem;
    font-weight: 600;
    color: #2C1F15;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .prose h3 {
    font-family: 'Lora', serif;
    font-size: 1.05rem;
    font-weight: 600;
    color: #2C1F15;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }
  .prose p {
    color: #5C4A38;
    font-size: 0.95rem;
    line-height: 1.8;
    margin-bottom: 1rem;
  }
  .prose strong {
    color: #2C1F15;
    font-weight: 500;
  }
  .prose ul {
    list-style: disc;
    padding-left: 1.5rem;
    color: #5C4A38;
    font-size: 0.95rem;
  }
  .prose li {
    margin-bottom: 0.25rem;
    line-height: 1.7;
  }
</style>
