---
import Base from '../../layouts/Base.astro';
import EnquiryForm from '../../components/EnquiryForm.astro';
---

<Base title="Make an Enquiry" description="Get in touch about rabbits for sale, boarding, or anything rabbit-related.">

  <div class="max-w-4xl mx-auto px-6 py-14">

    <div class="grid grid-cols-1 lg:grid-cols-5 gap-10">

      <!-- Left: info -->
      <div class="lg:col-span-2">
        <p class="section-tag">No pressure</p>
        <h1 class="font-lora text-3xl font-semibold text-bunny-dark mb-3">
          Get in touch
        </h1>
        <p class="text-bunny-light text-sm leading-relaxed mb-8">
          Whether you're interested in a rabbit, want to book boarding, or just have a question —
          drop us a message and we'll get back to you within 24 hours.
        </p>

        <div class="space-y-5">
          {[
            {
              icon: '🐇',
              title: 'Rabbit enquiries',
              desc: 'Tell us which rabbit you\'re interested in, or describe what you\'re looking for. We\'ll let you know of upcoming litters too.',
            },
            {
              icon: '🏠',
              title: 'Boarding',
              desc: 'For boarding bookings, use the dedicated form on our Boarding page — it captures all the details we need.',
              link: '/boarding',
              linkText: 'Go to boarding page →',
            },
            {
              icon: '📖',
              title: 'Just a question',
              desc: 'Happy to answer any rabbit care questions, even if you didn\'t buy from us.',
            },
          ].map(item => (
            <div class="flex gap-3">
              <span class="text-2xl flex-shrink-0 mt-0.5">{item.icon}</span>
              <div>
                <p class="font-medium text-bunny-dark text-sm">{item.title}</p>
                <p class="text-bunny-light text-xs leading-relaxed mt-0.5">{item.desc}</p>
                {item.link && (
                  <a href={item.link} class="text-xs text-terracotta no-underline hover:underline mt-1 inline-block">{item.linkText}</a>
                )}
              </div>
            </div>
          ))}
        </div>

        <div class="mt-8 p-4 bg-cream border border-tan rounded-xl text-xs text-bunny-mid">
          <p>💳 <strong class="text-bunny-dark">Payments:</strong> In person at collection, card machine, or bank transfer. No online payments.</p>
          <p class="mt-1.5">📦 <strong class="text-bunny-dark">No shipping:</strong> All rabbits are collected in person.</p>
        </div>
      </div>

      <!-- Right: form -->
      <div class="lg:col-span-3 bg-white border border-tan rounded-2xl p-7">
        <h2 class="font-lora font-semibold text-bunny-dark text-xl mb-5">Send us a message</h2>
        <EnquiryForm subject="General website enquiry" />
      </div>

    </div>
  </div>

</Base>
